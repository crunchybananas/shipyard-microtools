rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any authenticated user can read and write
    // (tighten to self-only + bot prefix once stable)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Workspaces: members can read, owner can write, accept-invite can update
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    // Invites: anyone can read (for invite link landing pages),
    // authenticated users can create and accept
    match /invites/{inviteId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Channels: members can read and write messages
    match /channels/{channelId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid;
        allow update: if request.auth != null;
      }

      // Threads subcollection
      match /threads/{threadId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;

        match /messages/{messageId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null
            && request.resource.data.authorId == request.auth.uid;
          allow update: if request.auth != null;
        }
      }

      // Typing indicators
      match /typing/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.uid == userId;
      }
    }
  }
}
